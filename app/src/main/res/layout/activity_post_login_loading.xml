<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient">

    <View
        android:id="@+id/orb_large"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_loading_orb"
        android:alpha="0.8"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/orb_small"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_loading_orb"
        android:alpha="0.55"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:layout_width="164dp"
            android:layout_height="164dp">

            <View
                android:id="@+id/ring_one"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@drawable/bg_auth_badge"
                android:alpha="0.7" />

            <View
                android:id="@+id/ring_two"
                android:layout_width="136dp"
                android:layout_height="136dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_auth_badge"
                android:alpha="0.55" />

            <ImageView
                android:id="@+id/image_logo"
                android:layout_width="108dp"
                android:layout_height="108dp"
                android:layout_gravity="center"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/app_logo" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="@string/loading_title"
            android:textColor="@color/ink"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/loading_subtitle"
            android:textColor="@color/ink_muted"
            android:textSize="15sp" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_loading"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:indeterminate="true"
            app:indicatorColor="@color/primary"
            app:trackColor="@color/accent_soft" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
