<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ExpensePilot" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.ExpensePilot.Button.Outlined</item>
        <item name="toolbarStyle">@style/Widget.ExpensePilot.Toolbar</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.ExpensePilot.BottomSheet</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:navigationBarColor">@color/surface_card</item>
    </style>

    <style name="Widget.ExpensePilot.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@android:color/transparent</item>
        <item name="titleTextColor">@color/ink</item>
        <item name="subtitleTextColor">@color/ink_muted</item>
    </style>

    <style name="Widget.ExpensePilot.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ThemeOverlay.ExpensePilot.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.ExpensePilot.BottomSheet</item>
    </style>

    <style name="Widget.ExpensePilot.BottomSheet" parent="Widget.Material3.BottomSheet.Modal" tools:targetApi="lollipop">
        <item name="android:background">@drawable/bg_sheet</item>
    </style>
</resources>
